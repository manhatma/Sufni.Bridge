<UserControl
    x:Class="Sufni.Bridge.Views.ItemLists.SessionListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Sufni.Bridge.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:v="clr-namespace:Sufni.Bridge.Views"
    xmlns:vm="clr-namespace:Sufni.Bridge.ViewModels"
    xmlns:vmi="clr-namespace:Sufni.Bridge.ViewModels.Items"
    xmlns:vml="clr-namespace:Sufni.Bridge.ViewModels.ItemLists"
    d:DesignHeight="600"
    d:DesignWidth="500"
    x:DataType="vml:SessionListViewModel"
    Background="{StaticResource SufniRegion}"
    mc:Ignorable="d">

    <Design.DataContext>
        <vml:SessionListViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Button.compare-toggle">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#D0D0D0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#505558" />
        </Style>
        <Style Selector="Button.compare-toggle-active">
            <Setter Property="Background" Value="#3288bd" />
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.compare-item">
            <Setter Property="Background" Value="{StaticResource SufniRegion}" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="10,0" />
        </Style>
        <Style Selector="Button.compare-item:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1f2327" />
        </Style>
        <Style Selector="Button.compare-open">
            <Setter Property="Background" Value="#3288bd" />
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0,12" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Margin" Value="10,5" />
        </Style>
        <Style Selector="Button.filter-toggle">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#D0D0D0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#505558" />
        </Style>
        <Style Selector="Button.filter-toggle.filter-indicator">
            <Setter Property="Background" Value="#2a5a7a" />
            <Setter Property="BorderBrush" Value="#3288bd" />
            <Setter Property="Foreground" Value="#ffffff" />
        </Style>
        <Style Selector="Button.filter-toggle-active">
            <Setter Property="Background" Value="#3288bd" />
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.combine-toggle">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#D0D0D0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#505558" />
        </Style>
        <Style Selector="Button.combine-toggle-active">
            <Setter Property="Background" Value="#66c2a5" />
            <Setter Property="Foreground" Value="#15191c" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.combine-open">
            <Setter Property="Background" Value="#66c2a5" />
            <Setter Property="Foreground" Value="#15191c" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0,12" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Margin" Value="10,5" />
        </Style>
        <Style Selector="Button.delete-toggle">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#D0D0D0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#505558" />
        </Style>
        <Style Selector="Button.delete-toggle-active">
            <Setter Property="Background" Value="#e34a33" />
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.delete-open">
            <Setter Property="Background" Value="#e34a33" />
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0,12" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Margin" Value="10,5" />
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="*" RowDefinitions="auto auto * auto auto auto">

        <!-- Filter + Delete + Combine + Compare mode toggle buttons -->
        <Grid Grid.Row="0" Margin="10,8,10,0" ColumnDefinitions="auto auto * auto auto">
            <Button Grid.Column="0"
                    Classes.filter-toggle="{Binding !IsFilterMenuOpen}"
                    Classes.filter-toggle-active="{Binding IsFilterMenuOpen}"
                    Classes.filter-indicator="{Binding IsFilterActive}"
                    Command="{Binding ToggleFilterMenuCommand}">
                <TextBlock Text="Filter" />
            </Button>
            <Button Grid.Column="1" Margin="6,0,0,0"
                    Classes.delete-toggle="{Binding !IsDeleteMode}"
                    Classes.delete-toggle-active="{Binding IsDeleteMode}"
                    Command="{Binding ToggleDeleteModeCommand}">
                <Panel>
                    <TextBlock Text="Delete" IsVisible="{Binding !IsDeleteMode}" />
                    <TextBlock Text="Cancel" IsVisible="{Binding IsDeleteMode}" Foreground="#ffffff" />
                </Panel>
            </Button>
            <Button Grid.Column="3" Margin="0,0,6,0"
                    Classes.combine-toggle="{Binding !IsCombineMode}"
                    Classes.combine-toggle-active="{Binding IsCombineMode}"
                    Command="{Binding ToggleCombineModeCommand}">
                <Panel>
                    <TextBlock Text="Combine" IsVisible="{Binding !IsCombineMode}" />
                    <TextBlock Text="Cancel" IsVisible="{Binding IsCombineMode}" Foreground="#15191c" />
                </Panel>
            </Button>
            <Button Grid.Column="4"
                    Classes.compare-toggle="{Binding !IsCompareMode}"
                    Classes.compare-toggle-active="{Binding IsCompareMode}"
                    Command="{Binding ToggleCompareModeCommand}">
                <Panel>
                    <TextBlock Text="Compare" IsVisible="{Binding !IsCompareMode}" />
                    <TextBlock Text="Cancel" IsVisible="{Binding IsCompareMode}" Foreground="#ffffff" />
                </Panel>
            </Button>
        </Grid>

        <!-- Setup filter menu -->
        <Border Grid.Row="1" Margin="10,6,10,0" Padding="8"
                Background="#1f2327" CornerRadius="6" BorderBrush="#505558" BorderThickness="1"
                IsVisible="{Binding IsFilterMenuOpen}">
            <ItemsRepeater ItemsSource="{Binding SetupFilters}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="2" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vml:SetupFilterItem">
                        <Button Background="Transparent" Padding="4,6" CornerRadius="4"
                                HorizontalAlignment="Stretch"
                                Command="{Binding $parent[UserControl].((vml:SessionListViewModel)DataContext).ToggleSetupFilterCommand}"
                                CommandParameter="{Binding}">
                            <Grid ColumnDefinitions="24 *">
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked}"
                                          IsHitTestVisible="False" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                           VerticalAlignment="Center" FontSize="13" Foreground="#D0D0D0" />
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </Border>

        <!--  Normal list of Sessions (hidden in compare/combine mode) -->
        <controls:PullableMenuScrollViewer
            Grid.Row="2"
            Grid.Column="0"
            Margin="0,15,0,5"
            Items="{Binding Items}"
            MenuItems="{Binding MenuItems}">
            <controls:PullableMenuScrollViewer.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.And}">
                    <Binding Path="!IsCompareMode" />
                    <Binding Path="!IsCombineMode" />
                    <Binding Path="!IsDeleteMode" />
                </MultiBinding>
            </controls:PullableMenuScrollViewer.IsVisible>
            <controls:PullableMenuScrollViewer.TopContent>
                <controls:SearchBarWithDateFilter />
            </controls:PullableMenuScrollViewer.TopContent>
        </controls:PullableMenuScrollViewer>

        <!-- Compare mode session list with checkboxes -->
        <ScrollViewer Grid.Row="2" Margin="0,15,0,5" IsVisible="{Binding IsCompareMode}">
            <ItemsRepeater ItemsSource="{Binding Items}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vmi:ItemViewModelBase">
                        <StackPanel>
                            <Button Height="48"
                                    HorizontalAlignment="Stretch"
                                    VerticalContentAlignment="Center"
                                    Classes="compare-item"
                                    Command="{Binding $parent[UserControl].((vml:SessionListViewModel)DataContext).ToggleCompareSelectionCommand}"
                                    CommandParameter="{Binding}">
                                <Grid ColumnDefinitions="30 auto * auto" HorizontalAlignment="Stretch">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelectedForCompare}"
                                              IsHitTestVisible="False" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="{Binding Timestamp}"
                                               VerticalAlignment="Center" Foreground="#808080" />
                                </Grid>
                            </Button>
                            <Separator Height="1" Margin="0"
                                       Background="{StaticResource SufniBackgroundDisabled}" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- Compare button (visible when 2+ sessions selected) -->
        <Button Grid.Row="3"
                Classes="compare-open"
                IsVisible="{Binding IsCompareMode}"
                Command="{Binding OpenComparisonCommand}">
            <TextBlock Foreground="#ffffff">
                <Run Text="Compare" />
                <Run Text="{Binding CompareSelectionCount, StringFormat=' ({0})'}" />
            </TextBlock>
        </Button>

        <!-- Combine mode session list with checkboxes -->
        <ScrollViewer Grid.Row="2" Margin="0,15,0,5" IsVisible="{Binding IsCombineMode}">
            <ItemsRepeater ItemsSource="{Binding Items}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vmi:ItemViewModelBase">
                        <StackPanel>
                            <Button Height="48"
                                    HorizontalAlignment="Stretch"
                                    VerticalContentAlignment="Center"
                                    Classes="compare-item"
                                    Command="{Binding $parent[UserControl].((vml:SessionListViewModel)DataContext).ToggleCombineSelectionCommand}"
                                    CommandParameter="{Binding}">
                                <Grid ColumnDefinitions="30 auto * auto" HorizontalAlignment="Stretch">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelectedForCompare}"
                                              IsHitTestVisible="False" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="{Binding Timestamp}"
                                               VerticalAlignment="Center" Foreground="#808080" />
                                </Grid>
                            </Button>
                            <Separator Height="1" Margin="0"
                                       Background="{StaticResource SufniBackgroundDisabled}" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- Combine button + setup mismatch warning -->
        <StackPanel Grid.Row="3" IsVisible="{Binding IsCombineMode}">
            <TextBlock Text="Setup mismatch — selected sessions use different setups"
                       Foreground="#e55039" FontSize="12" Margin="10,4"
                       HorizontalAlignment="Center"
                       IsVisible="{Binding CombineSetupMismatch}" />
            <TextBlock Text="Maximum nesting depth (3) exceeded"
                       Foreground="#e55039" FontSize="12" Margin="10,4"
                       HorizontalAlignment="Center"
                       IsVisible="{Binding CombineDepthExceeded}" />
            <Button Classes="combine-open"
                    Command="{Binding CombineSessionsCommand}">
                <Button.IsEnabled>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="!CombineSetupMismatch" />
                        <Binding Path="!CombineDepthExceeded" />
                    </MultiBinding>
                </Button.IsEnabled>
                <Panel>
                    <TextBlock Foreground="#15191c" IsVisible="{Binding !IsCombining}">
                        <Run Text="Combine" />
                        <Run Text="{Binding CombineSelectionCount, StringFormat=' ({0})'}" />
                    </TextBlock>
                    <TextBlock Text="Combining..." Foreground="#15191c" IsVisible="{Binding IsCombining}" />
                </Panel>
            </Button>
        </StackPanel>

        <!-- Delete mode session list with checkboxes -->
        <ScrollViewer Grid.Row="2" Margin="0,15,0,5" IsVisible="{Binding IsDeleteMode}">
            <ItemsRepeater ItemsSource="{Binding Items}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vmi:ItemViewModelBase">
                        <StackPanel>
                            <Button Height="48"
                                    HorizontalAlignment="Stretch"
                                    VerticalContentAlignment="Center"
                                    Classes="compare-item"
                                    Command="{Binding $parent[UserControl].((vml:SessionListViewModel)DataContext).ToggleDeleteSelectionCommand}"
                                    CommandParameter="{Binding}">
                                <Grid ColumnDefinitions="30 auto * auto" HorizontalAlignment="Stretch">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelectedForCompare}"
                                              IsHitTestVisible="False" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="{Binding Timestamp}"
                                               VerticalAlignment="Center" Foreground="#808080" />
                                </Grid>
                            </Button>
                            <Separator Height="1" Margin="0"
                                       Background="{StaticResource SufniBackgroundDisabled}" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- Delete button -->
        <Button Grid.Row="3"
                Classes="delete-open"
                IsVisible="{Binding IsDeleteMode}"
                Command="{Binding DeleteSelectedSessionsCommand}">
            <TextBlock Foreground="#ffffff">
                <Run Text="{Binding DeleteConfirmLabel}" />
                <Run Text="{Binding DeleteSelectionCount, StringFormat=' ({0})'}" />
            </TextBlock>
        </Button>

        <!--  Notifications  -->
        <controls:NotificationsBar
            Grid.Row="4"
            Grid.Column="0"
            Margin="5,0"
            ZIndex="10" />

        <!--  Error messages  -->
        <controls:ErrorMessagesBar
            Grid.Row="5"
            Grid.Column="0"
            Margin="5,0"
            ZIndex="10" />

        <!--  Undo last deleted  -->
        <controls:UndoDeleteButton
            Grid.Row="0"
            Grid.RowSpan="6"
            Grid.Column="0" />
    </Grid>
</UserControl>
