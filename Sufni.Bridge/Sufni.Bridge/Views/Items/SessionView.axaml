<UserControl
    x:Class="Sufni.Bridge.Views.Items.SessionView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
    xmlns:ia="clr-namespace:Avalonia.Xaml.Interactions.Core;assembly=Avalonia.Xaml.Interactions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:plots="clr-namespace:Sufni.Bridge.Views.Plots"
    xmlns:sessionpages="clr-namespace:Sufni.Bridge.Views.SessionPages"
    xmlns:v="clr-namespace:Sufni.Bridge.Views.Controls"
    xmlns:vm="clr-namespace:Sufni.Bridge.ViewModels.Items"
    d:DesignHeight="600"
    d:DesignWidth="500"
    x:DataType="vm:SessionViewModel"
    Background="{StaticResource SufniRegion}"
    Focusable="True"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:SessionViewModel />
    </Design.DataContext>

    <Grid Margin="10,0,10,0" RowDefinitions="auto auto * auto auto">

        <!--  Name  -->
        <v:EditableTitle
            Grid.Row="0"
            Margin="15,0,20,10"
            HorizontalAlignment="Stretch" />

        <!--  Tab headers  -->
        <ItemsControl
            Name="TabHeaders"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            ItemsSource="{Binding Pages}">

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button
                        Name="{Binding DisplayName}"
                        HorizontalAlignment="Center"
                        Classes="tabheader"
                        Click="OnTabHeaderClicked"
                        Content="{Binding DisplayName}}"
                        IsEnabled="{Binding !Selected, Mode=TwoWay}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>

            <ItemsControl.Styles>
                <Style Selector="Button.tabheader">
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="CornerRadius" Value="0" />
                    <Setter Property="Padding" Value="0,0,0,10" />
                </Style>
                <Style Selector="Button.tabheader:pressed /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="Foreground" Value="{StaticResource SufniForeground}" />
                    <Setter Property="Background" Value="Transparent" />
                </Style>
                <Style Selector="Button.tabheader:pressed /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="Background" Value="Transparent" />
                </Style>
                <Style Selector="Button.tabheader:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="Background" Value="Transparent" />
                </Style>
                <Style Selector="Button.tabheader:disabled /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="Foreground" Value="{StaticResource SufniForeground}" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="{StaticResource SufniAccentColor}" />
                    <Setter Property="Padding" Value="0,0,0,8" />
                    <Setter Property="BorderThickness" Value="0,0,0,2" />
                </Style>
            </ItemsControl.Styles>

        </ItemsControl>

        <ScrollViewer
            Name="TabScrollViewer"
            Grid.Row="2"
            HorizontalScrollBarVisibility="Hidden"
            HorizontalSnapPointsAlignment="Far"
            HorizontalSnapPointsType="MandatorySingle"
            IsScrollChainingEnabled="False"
            IsScrollInertiaEnabled="False"
            PropertyChanged="TabScrollViewer_OnPropertyChanged"
            SizeChanged="TabScrollViewer_OnSizeChanged"
            VerticalScrollBarVisibility="Disabled">
            <ItemsControl Name="TabContainer" ItemsSource="{Binding Pages}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <!--  Ensure that the SufniTelemetryPlotViews' Telemetry property is set  -->
                <i:Interaction.Behaviors>
                    <ia:EventTriggerBehavior EventName="Loaded">
                        <InvokeCommandAction Command="{Binding LoadedCommand}" CommandParameter="{Binding ElementName=TabScrollViewer, Path=Bounds}" />
                    </ia:EventTriggerBehavior>
                </i:Interaction.Behaviors>

            </ItemsControl>
        </ScrollViewer>

        <!--  Error messages for Session instance  -->
        <v:ErrorMessagesBar Grid.Row="3" Margin="10,5,10,0" />

        <!--  Crop page overlay  -->
        <Panel
            Grid.Row="2"
            IsVisible="{Binding IsCropVisible}"
            ZIndex="50"
            Background="{StaticResource SufniRegion}">
            <sessionpages:CropPageView DataContext="{Binding CropPage}" />
        </Panel>

        <!--  Back, Save, Crop, PDF, Reset and Delete buttons  -->
        <Grid
            Grid.Row="4"
            Margin="10,15,10,5"
            ColumnDefinitions="auto * auto auto auto auto"
            RowDefinitions="39">
            <Button
                Grid.Row="0"
                Grid.Column="0"
                Width="39"
                Height="39"
                Margin="0,0,10,0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding OpenPreviousPageCommand}">
                <Image
                    Width="16"
                    Height="16"
                    Source="{SvgImage /Assets/fa-arrow-left.svg}" />
            </Button>
            <Button
                Grid.Row="0"
                Grid.Column="1"
                Margin="0,0,10,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding ContextSaveCommand}"
                Content="{Binding SaveLabel}" />
            <Button
                Grid.Row="0"
                Grid.Column="2"
                Width="39"
                Height="39"
                Margin="0,0,5,0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding ToggleCropPageCommand}"
                IsVisible="{Binding ShowPdfExportButton}"
                Svg.Css=".default { fill: #a0a0a0; }">
                <Image
                    Width="20"
                    Height="20"
                    Source="{SvgImage /Assets/fa-crop.svg}" />
            </Button>
            <Button
                Grid.Row="0"
                Grid.Column="3"
                Width="39"
                Height="39"
                Margin="0,0,5,0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding ExportPdfCommand}"
                IsVisible="{Binding ShowPdfExportButton}"
                Svg.Css=".default { fill: #a0a0a0; }">
                <Image
                    Width="16"
                    Height="16"
                    Source="{SvgImage /Assets/fa-file-pdf.svg}" />
            </Button>
            <Button
                Grid.Row="0"
                Grid.Column="4"
                Width="39"
                Height="39"
                Margin="0,0,5,0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding ContextResetCommand}">
                <Image
                    Width="16"
                    Height="16"
                    Source="{SvgImage /Assets/fa-rotate-left.svg}" />
            </Button>
            <Button
                Name="DeleteButton"
                Grid.Row="0"
                Grid.Column="5"
                Width="39"
                Height="39"
                Margin="0,0,2,0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding FakeDeleteCommand}">
                <Button.Flyout>
                    <Flyout
                        HorizontalOffset="40"
                        Placement="Left"
                        PlacementAnchor="Right">
                        <StackPanel
                            Width="{Binding $parent[Grid].Bounds.Width}"
                            FlowDirection="RightToLeft"
                            Orientation="Horizontal">
                            <Button
                                Name="CancelDeleteButton"
                                VerticalContentAlignment="Center"
                                Classes="embedded"
                                Click="CancelDeleteButton_Click"
                                Content="cancel" />
                            <Button
                                Name="InnerDeleteButton"
                                Margin="5,0,0,0"
                                VerticalContentAlignment="Center"
                                Classes="embedded dangerous"
                                Command="{Binding DeleteCommand}"
                                CommandParameter="{x:True}"
                                Content="delete" />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
                <Image
                    Width="16"
                    Height="16"
                    Source="{SvgImage /Assets/fa-trash-can.svg}" />
            </Button>
        </Grid>

        <!--  Session Loading Overlay  -->
        <Panel
            Grid.Row="0"
            Grid.RowSpan="5"
            IsVisible="{Binding IsAnalyzingData}"
            ZIndex="100"
            Background="#CC15191C">
            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#20262b"
                BorderBrush="#505050"
                BorderThickness="1"
                CornerRadius="12"
                Padding="32,24">
                <StackPanel MinWidth="200" Spacing="14">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="13"
                        Foreground="#a0a0a0"
                        Text="Analyzing time history data …" />
                    <ProgressBar
                        Height="3"
                        CornerRadius="2"
                        Background="#30ffffff"
                        Foreground="#0078d7"
                        IsIndeterminate="True" />
                </StackPanel>
            </Border>
        </Panel>

        <!--  PDF Export Loading Overlay  -->
        <Panel
            Grid.Row="0"
            Grid.RowSpan="5"
            IsVisible="{Binding IsGeneratingPdf}"
            ZIndex="100"
            Background="#CC15191C">
            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#20262b"
                BorderBrush="#505050"
                BorderThickness="1"
                CornerRadius="12"
                Padding="32,24">
                <StackPanel MinWidth="200" Spacing="14">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="13"
                        Foreground="#a0a0a0"
                        Text="Generating PDF …" />
                    <ProgressBar
                        Height="3"
                        CornerRadius="2"
                        Background="#30ffffff"
                        Foreground="#0078d7"
                        IsIndeterminate="True" />
                </StackPanel>
            </Border>
        </Panel>

    </Grid>
</UserControl>