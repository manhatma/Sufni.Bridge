<UserControl
    x:Class="Sufni.Bridge.Views.SessionPages.BalancePageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Sufni.Bridge.ViewModels.SessionPages"
    d:DesignHeight="600"
    d:DesignWidth="500"
    x:DataType="vm:BalancePageViewModel"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:BalancePageViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="TextBlock.metricLabel">
            <Setter Property="Foreground" Value="#D0D0D0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.metricValue">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8,0" />
        </Style>
        <Style Selector="TextBlock.metricTarget">
            <Setter Property="Foreground" Value="#808890" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="80" />
        </Style>
        <Style Selector="Grid.metricRow">
            <Setter Property="Margin" Value="0,2" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer Width="{Binding $parent[ScrollViewer].Bounds.Width}" Height="{Binding $parent[ScrollViewer].Bounds.Height}" IsScrollChainingEnabled="False">
        <StackPanel Orientation="Vertical">
            <Border Background="#20262B" BorderBrush="#505558" BorderThickness="1"
                    CornerRadius="4" Padding="10" Margin="6">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Balance metrics" Foreground="#D0D0D0" FontSize="14"
                               FontWeight="SemiBold" Margin="0,0,0,6" />

                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.FrontSag.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.FrontSag.Value}"  Foreground="{Binding Metrics.FrontSag.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.FrontSag.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.RearSag.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.RearSag.Value}"  Foreground="{Binding Metrics.RearSag.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.RearSag.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.SagDiff.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.SagDiff.Value}"  Foreground="{Binding Metrics.SagDiff.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.SagDiff.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.FrontP95.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.FrontP95.Value}"  Foreground="{Binding Metrics.FrontP95.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.FrontP95.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.RearP95.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.RearP95.Value}"  Foreground="{Binding Metrics.RearP95.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.RearP95.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.P95Diff.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.P95Diff.Value}"  Foreground="{Binding Metrics.P95Diff.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.P95Diff.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.FrontBO.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.FrontBO.Value}"  Foreground="{Binding Metrics.FrontBO.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.FrontBO.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.RearBO.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.RearBO.Value}"  Foreground="{Binding Metrics.RearBO.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.RearBO.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.CompVelRatio.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.CompVelRatio.Value}"  Foreground="{Binding Metrics.CompVelRatio.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.CompVelRatio.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.RebVelRatio.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.RebVelRatio.Value}"  Foreground="{Binding Metrics.RebVelRatio.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.RebVelRatio.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.CompMsd.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.CompMsd.Value}"  Foreground="{Binding Metrics.CompMsd.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.CompMsd.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.RebMsd.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.RebMsd.Value}"  Foreground="{Binding Metrics.RebMsd.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.RebMsd.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.FrontFreq.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.FrontFreq.Value}"  Foreground="{Binding Metrics.FrontFreq.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.FrontFreq.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.RearFreq.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.RearFreq.Value}"  Foreground="{Binding Metrics.RearFreq.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.RearFreq.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.FreqDiff.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.FreqDiff.Value}"  Foreground="{Binding Metrics.FreqDiff.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.FreqDiff.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.PeakAmpRatio.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.PeakAmpRatio.Value}"  Foreground="{Binding Metrics.PeakAmpRatio.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.PeakAmpRatio.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.LowEnergyRatio.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.LowEnergyRatio.Value}"  Foreground="{Binding Metrics.LowEnergyRatio.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.LowEnergyRatio.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.MidEnergyRatio.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.MidEnergyRatio.Value}"  Foreground="{Binding Metrics.MidEnergyRatio.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.MidEnergyRatio.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.WheelEnergyRatio.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.WheelEnergyRatio.Value}"  Foreground="{Binding Metrics.WheelEnergyRatio.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.WheelEnergyRatio.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.HighEnergyRatio.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.HighEnergyRatio.Value}"  Foreground="{Binding Metrics.HighEnergyRatio.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.HighEnergyRatio.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.LowCoherence.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.LowCoherence.Value}"  Foreground="{Binding Metrics.LowCoherence.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.LowCoherence.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.MidCoherence.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.MidCoherence.Value}"  Foreground="{Binding Metrics.MidCoherence.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.MidCoherence.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.WheelCoherence.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.WheelCoherence.Value}"  Foreground="{Binding Metrics.WheelCoherence.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.WheelCoherence.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.HighCoherence.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.HighCoherence.Value}"  Foreground="{Binding Metrics.HighCoherence.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.HighCoherence.Target}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Wheel-load (dynamic) section. Values stay "—" until the session has a
                 spring component assigned in Setup and a parsable spring-rate value. -->
            <Border Background="#20262B" BorderBrush="#505558" BorderThickness="1"
                    CornerRadius="4" Padding="10" Margin="6">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Wheel load (dynamic)" Foreground="#D0D0D0" FontSize="14"
                               FontWeight="SemiBold" Margin="0,0,0,6" />
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.FrontStaticForce.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.FrontStaticForce.Value}"  Foreground="{Binding Metrics.FrontStaticForce.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.FrontStaticForce.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.RearStaticForce.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.RearStaticForce.Value}"  Foreground="{Binding Metrics.RearStaticForce.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.RearStaticForce.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.FrontUnloading.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.FrontUnloading.Value}"  Foreground="{Binding Metrics.FrontUnloading.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.FrontUnloading.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.RearUnloading.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.RearUnloading.Value}"  Foreground="{Binding Metrics.RearUnloading.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.RearUnloading.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.UnloadingDiff.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.UnloadingDiff.Value}"  Foreground="{Binding Metrics.UnloadingDiff.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.UnloadingDiff.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.FrontUnloadEv.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.FrontUnloadEv.Value}"  Foreground="{Binding Metrics.FrontUnloadEv.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.FrontUnloadEv.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.RearUnloadEv.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.RearUnloadEv.Value}"  Foreground="{Binding Metrics.RearUnloadEv.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.RearUnloadEv.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.FrontDynRange.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.FrontDynRange.Value}"  Foreground="{Binding Metrics.FrontDynRange.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.FrontDynRange.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.RearDynRange.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.RearDynRange.Value}"  Foreground="{Binding Metrics.RearDynRange.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.RearDynRange.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.DynRangeDiff.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.DynRangeDiff.Value}"  Foreground="{Binding Metrics.DynRangeDiff.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.DynRangeDiff.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.LowLoadMichelson.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.LowLoadMichelson.Value}"  Foreground="{Binding Metrics.LowLoadMichelson.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.LowLoadMichelson.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.MidLoadMichelson.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.MidLoadMichelson.Value}"  Foreground="{Binding Metrics.MidLoadMichelson.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.MidLoadMichelson.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.WheelLoadMichelson.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.WheelLoadMichelson.Value}"  Foreground="{Binding Metrics.WheelLoadMichelson.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.WheelLoadMichelson.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.HighLoadMichelson.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.HighLoadMichelson.Value}"  Foreground="{Binding Metrics.HighLoadMichelson.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.HighLoadMichelson.Target}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Image IsVisible="{Binding CombinedBalance, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding CombinedBalance}" />
            <Image IsVisible="{Binding ReboundBalance, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding ReboundBalance}" />
            <Image IsVisible="{Binding CompressionBalance, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding CompressionBalance}" />
            <Image IsVisible="{Binding CombinedVelocityFft, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding CombinedVelocityFft}" />
            <Image IsVisible="{Binding CombinedTravelFft, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding CombinedTravelFft}" />
            <Image IsVisible="{Binding CombinedTravelFftHigh, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding CombinedTravelFftHigh}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
