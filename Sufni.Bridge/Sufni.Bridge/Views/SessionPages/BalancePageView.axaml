<UserControl
    x:Class="Sufni.Bridge.Views.SessionPages.BalancePageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Sufni.Bridge.ViewModels.SessionPages"
    d:DesignHeight="600"
    d:DesignWidth="500"
    x:DataType="vm:BalancePageViewModel"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:BalancePageViewModel />
    </Design.DataContext>

    <UserControl.Resources>
        <!--  Shrink the Fluent text-control min height for the compact inline target editors.  -->
        <x:Double x:Key="TextControlThemeMinHeight">22</x:Double>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="TextBlock.metricLabel">
            <Setter Property="Foreground" Value="#D0D0D0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.metricValue">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8,0" />
        </Style>
        <Style Selector="TextBlock.metricTarget">
            <Setter Property="Foreground" Value="#808890" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="80" />
        </Style>
        <Style Selector="Grid.metricRow">
            <Setter Property="Margin" Value="0,2" />
        </Style>
        <Style Selector="StackPanel.targetEditor">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Spacing" Value="2" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.editDash">
            <Setter Property="Foreground" Value="#808890" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="NumericUpDown.balanceEdit">
            <Setter Property="ShowButtonSpinner" Value="False" />
            <Setter Property="Height" Value="22" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="MaxWidth" Value="46" />
            <Setter Property="Minimum" Value="-100" />
            <Setter Property="Maximum" Value="200" />
            <Setter Property="Increment" Value="1" />
            <Setter Property="FormatString" Value="0.#" />
            <Setter Property="ClipValueToMinMax" Value="True" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <!--  The bordered box is the NumericUpDown's inner ButtonSpinner. Its theme MinHeight
              (~32) stayed taller than our Height and got clipped, so the top/bottom borders
              vanished. Collapse the spinner's and the editor's min height + padding.  -->
        <Style Selector="NumericUpDown.balanceEdit /template/ ButtonSpinner">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="NumericUpDown.balanceEdit /template/ TextBox">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="3,0" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style Selector="ToggleButton.pencil">
            <Setter Property="Padding" Value="4" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="ToggleButton.pencil /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="ToggleButton.pencil:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer Width="{Binding $parent[ScrollViewer].Bounds.Width}" Height="{Binding $parent[ScrollViewer].Bounds.Height}" IsScrollChainingEnabled="False">
        <StackPanel Orientation="Vertical">
            <Border Background="#20262B" BorderBrush="#505558" BorderThickness="1"
                    CornerRadius="4" Padding="10" Margin="6">
                <StackPanel Orientation="Vertical">
                    <Grid ColumnDefinitions="* Auto Auto" Margin="0,0,0,6">
                        <TextBlock Grid.Column="0" Text="Balance metrics" Foreground="#D0D0D0" FontSize="14"
                                   FontWeight="SemiBold" VerticalAlignment="Center" />
                        <ToggleButton Grid.Column="1" Classes="pencil" IsChecked="{Binding Metrics.IsEditing}"
                                      IsVisible="{Binding !Metrics.IsEditing}" ToolTip.Tip="Edit target ranges">
                            <Image Width="13" Source="{SvgImage /Assets/fa-pen-square.svg}" />
                        </ToggleButton>
                        <Button Grid.Column="1" Classes="embedded" Command="{Binding Metrics.ConfirmEditCommand}"
                                IsVisible="{Binding Metrics.IsEditing}" ToolTip.Tip="Save changes">
                            <Image Width="14" Source="{SvgImage /Assets/fa-check_green.svg}" />
                        </Button>
                        <Button Grid.Column="2" Classes="embedded" Margin="10,0,0,0" Command="{Binding Metrics.CancelEditCommand}"
                                IsVisible="{Binding Metrics.IsEditing}" ToolTip.Tip="Discard changes">
                            <Image Width="12" Source="{SvgImage /Assets/fa-xmark.svg}" />
                        </Button>
                    </Grid>

                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.FrontSag.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.FrontSag.Value}"  Foreground="{Binding Metrics.FrontSag.ValueBrush}" />
                        <Panel Grid.Column="2">
                            <TextBlock Classes="metricTarget" Text="{Binding Metrics.FrontSag.Target}"
                                       IsVisible="{Binding Metrics.FrontSag.ShowTargetText}" />
                            <StackPanel Classes="targetEditor" IsVisible="{Binding Metrics.FrontSag.ShowEditors}">
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.FrontSag.GreenMin}" />
                                <TextBlock Classes="editDash" Text="–" IsVisible="{Binding Metrics.FrontSag.ShowMaxField}" />
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.FrontSag.GreenMax}"
                                               IsVisible="{Binding Metrics.FrontSag.ShowMaxField}" />
                                <Button Classes="embedded" Margin="2,0,0,0" Command="{Binding Metrics.ResetMetricCommand}"
                                        CommandParameter="{Binding Metrics.FrontSag}" ToolTip.Tip="Reset to default">
                                    <Image Width="10" Source="{SvgImage /Assets/fa-rotate-left.svg}" />
                                </Button>
                            </StackPanel>
                        </Panel>
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.RearSag.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.RearSag.Value}"  Foreground="{Binding Metrics.RearSag.ValueBrush}" />
                        <Panel Grid.Column="2">
                            <TextBlock Classes="metricTarget" Text="{Binding Metrics.RearSag.Target}"
                                       IsVisible="{Binding Metrics.RearSag.ShowTargetText}" />
                            <StackPanel Classes="targetEditor" IsVisible="{Binding Metrics.RearSag.ShowEditors}">
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.RearSag.GreenMin}" />
                                <TextBlock Classes="editDash" Text="–" IsVisible="{Binding Metrics.RearSag.ShowMaxField}" />
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.RearSag.GreenMax}"
                                               IsVisible="{Binding Metrics.RearSag.ShowMaxField}" />
                                <Button Classes="embedded" Margin="2,0,0,0" Command="{Binding Metrics.ResetMetricCommand}"
                                        CommandParameter="{Binding Metrics.RearSag}" ToolTip.Tip="Reset to default">
                                    <Image Width="10" Source="{SvgImage /Assets/fa-rotate-left.svg}" />
                                </Button>
                            </StackPanel>
                        </Panel>
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.SagDiff.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.SagDiff.Value}"  Foreground="{Binding Metrics.SagDiff.ValueBrush}" />
                        <Panel Grid.Column="2">
                            <TextBlock Classes="metricTarget" Text="{Binding Metrics.SagDiff.Target}"
                                       IsVisible="{Binding Metrics.SagDiff.ShowTargetText}" />
                            <StackPanel Classes="targetEditor" IsVisible="{Binding Metrics.SagDiff.ShowEditors}">
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.SagDiff.GreenMin}" />
                                <TextBlock Classes="editDash" Text="–" IsVisible="{Binding Metrics.SagDiff.ShowMaxField}" />
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.SagDiff.GreenMax}"
                                               IsVisible="{Binding Metrics.SagDiff.ShowMaxField}" />
                                <Button Classes="embedded" Margin="2,0,0,0" Command="{Binding Metrics.ResetMetricCommand}"
                                        CommandParameter="{Binding Metrics.SagDiff}" ToolTip.Tip="Reset to default">
                                    <Image Width="10" Source="{SvgImage /Assets/fa-rotate-left.svg}" />
                                </Button>
                            </StackPanel>
                        </Panel>
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.DamperSag.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.DamperSag.Value}"  Foreground="{Binding Metrics.DamperSag.ValueBrush}" />
                        <Panel Grid.Column="2">
                            <TextBlock Classes="metricTarget" Text="{Binding Metrics.DamperSag.Target}"
                                       IsVisible="{Binding Metrics.DamperSag.ShowTargetText}" />
                            <StackPanel Classes="targetEditor" IsVisible="{Binding Metrics.DamperSag.ShowEditors}">
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.DamperSag.GreenMin}" />
                                <TextBlock Classes="editDash" Text="–" IsVisible="{Binding Metrics.DamperSag.ShowMaxField}" />
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.DamperSag.GreenMax}"
                                               IsVisible="{Binding Metrics.DamperSag.ShowMaxField}" />
                                <Button Classes="embedded" Margin="2,0,0,0" Command="{Binding Metrics.ResetMetricCommand}"
                                        CommandParameter="{Binding Metrics.DamperSag}" ToolTip.Tip="Reset to default">
                                    <Image Width="10" Source="{SvgImage /Assets/fa-rotate-left.svg}" />
                                </Button>
                            </StackPanel>
                        </Panel>
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.FrontP95.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.FrontP95.Value}"  Foreground="{Binding Metrics.FrontP95.ValueBrush}" />
                        <Panel Grid.Column="2">
                            <TextBlock Classes="metricTarget" Text="{Binding Metrics.FrontP95.Target}"
                                       IsVisible="{Binding Metrics.FrontP95.ShowTargetText}" />
                            <StackPanel Classes="targetEditor" IsVisible="{Binding Metrics.FrontP95.ShowEditors}">
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.FrontP95.GreenMin}" />
                                <TextBlock Classes="editDash" Text="–" IsVisible="{Binding Metrics.FrontP95.ShowMaxField}" />
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.FrontP95.GreenMax}"
                                               IsVisible="{Binding Metrics.FrontP95.ShowMaxField}" />
                                <Button Classes="embedded" Margin="2,0,0,0" Command="{Binding Metrics.ResetMetricCommand}"
                                        CommandParameter="{Binding Metrics.FrontP95}" ToolTip.Tip="Reset to default">
                                    <Image Width="10" Source="{SvgImage /Assets/fa-rotate-left.svg}" />
                                </Button>
                            </StackPanel>
                        </Panel>
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.RearP95.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.RearP95.Value}"  Foreground="{Binding Metrics.RearP95.ValueBrush}" />
                        <Panel Grid.Column="2">
                            <TextBlock Classes="metricTarget" Text="{Binding Metrics.RearP95.Target}"
                                       IsVisible="{Binding Metrics.RearP95.ShowTargetText}" />
                            <StackPanel Classes="targetEditor" IsVisible="{Binding Metrics.RearP95.ShowEditors}">
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.RearP95.GreenMin}" />
                                <TextBlock Classes="editDash" Text="–" IsVisible="{Binding Metrics.RearP95.ShowMaxField}" />
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.RearP95.GreenMax}"
                                               IsVisible="{Binding Metrics.RearP95.ShowMaxField}" />
                                <Button Classes="embedded" Margin="2,0,0,0" Command="{Binding Metrics.ResetMetricCommand}"
                                        CommandParameter="{Binding Metrics.RearP95}" ToolTip.Tip="Reset to default">
                                    <Image Width="10" Source="{SvgImage /Assets/fa-rotate-left.svg}" />
                                </Button>
                            </StackPanel>
                        </Panel>
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.P95Diff.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.P95Diff.Value}"  Foreground="{Binding Metrics.P95Diff.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.P95Diff.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.EffectiveHeadAngle.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.EffectiveHeadAngle.Value}"  Foreground="{Binding Metrics.EffectiveHeadAngle.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.EffectiveHeadAngle.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.PitchAttitude.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.PitchAttitude.Value}"  Foreground="{Binding Metrics.PitchAttitude.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.PitchAttitude.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.PitchStability.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.PitchStability.Value}"  Foreground="{Binding Metrics.PitchStability.ValueBrush}" />
                        <Panel Grid.Column="2">
                            <TextBlock Classes="metricTarget" Text="{Binding Metrics.PitchStability.Target}"
                                       IsVisible="{Binding Metrics.PitchStability.ShowTargetText}" />
                            <StackPanel Classes="targetEditor" IsVisible="{Binding Metrics.PitchStability.ShowEditors}">
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.PitchStability.GreenMin}" />
                                <TextBlock Classes="editDash" Text="–" IsVisible="{Binding Metrics.PitchStability.ShowMaxField}" />
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.PitchStability.GreenMax}"
                                               IsVisible="{Binding Metrics.PitchStability.ShowMaxField}" />
                                <Button Classes="embedded" Margin="2,0,0,0" Command="{Binding Metrics.ResetMetricCommand}"
                                        CommandParameter="{Binding Metrics.PitchStability}" ToolTip.Tip="Reset to default">
                                    <Image Width="10" Source="{SvgImage /Assets/fa-rotate-left.svg}" />
                                </Button>
                            </StackPanel>
                        </Panel>
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.GoutSymmetry.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.GoutSymmetry.Value}"  Foreground="{Binding Metrics.GoutSymmetry.ValueBrush}" />
                        <Panel Grid.Column="2">
                            <TextBlock Classes="metricTarget" Text="{Binding Metrics.GoutSymmetry.Target}"
                                       IsVisible="{Binding Metrics.GoutSymmetry.ShowTargetText}" />
                            <StackPanel Classes="targetEditor" IsVisible="{Binding Metrics.GoutSymmetry.ShowEditors}">
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.GoutSymmetry.GreenMin}" />
                                <TextBlock Classes="editDash" Text="–" IsVisible="{Binding Metrics.GoutSymmetry.ShowMaxField}" />
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.GoutSymmetry.GreenMax}"
                                               IsVisible="{Binding Metrics.GoutSymmetry.ShowMaxField}" />
                                <Button Classes="embedded" Margin="2,0,0,0" Command="{Binding Metrics.ResetMetricCommand}"
                                        CommandParameter="{Binding Metrics.GoutSymmetry}" ToolTip.Tip="Reset to default">
                                    <Image Width="10" Source="{SvgImage /Assets/fa-rotate-left.svg}" />
                                </Button>
                            </StackPanel>
                        </Panel>
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.PitchModeEnergy.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.PitchModeEnergy.Value}"  Foreground="{Binding Metrics.PitchModeEnergy.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.PitchModeEnergy.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.FrontBO.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.FrontBO.Value}"  Foreground="{Binding Metrics.FrontBO.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.FrontBO.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.RearBO.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.RearBO.Value}"  Foreground="{Binding Metrics.RearBO.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.RearBO.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.CompVelRatio.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.CompVelRatio.Value}"  Foreground="{Binding Metrics.CompVelRatio.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.CompVelRatio.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.RebVelRatio.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.RebVelRatio.Value}"  Foreground="{Binding Metrics.RebVelRatio.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.RebVelRatio.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.CompMsd.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.CompMsd.Value}"  Foreground="{Binding Metrics.CompMsd.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.CompMsd.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.RebMsd.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.RebMsd.Value}"  Foreground="{Binding Metrics.RebMsd.ValueBrush}" />
                        <Panel Grid.Column="2">
                            <TextBlock Classes="metricTarget" Text="{Binding Metrics.RebMsd.Target}"
                                       IsVisible="{Binding Metrics.RebMsd.ShowTargetText}" />
                            <StackPanel Classes="targetEditor" IsVisible="{Binding Metrics.RebMsd.ShowEditors}">
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.RebMsd.GreenMin}" />
                                <TextBlock Classes="editDash" Text="–" IsVisible="{Binding Metrics.RebMsd.ShowMaxField}" />
                                <NumericUpDown Classes="balanceEdit" Value="{Binding Metrics.RebMsd.GreenMax}"
                                               IsVisible="{Binding Metrics.RebMsd.ShowMaxField}" />
                                <Button Classes="embedded" Margin="2,0,0,0" Command="{Binding Metrics.ResetMetricCommand}"
                                        CommandParameter="{Binding Metrics.RebMsd}" ToolTip.Tip="Reset to default">
                                    <Image Width="10" Source="{SvgImage /Assets/fa-rotate-left.svg}" />
                                </Button>
                            </StackPanel>
                        </Panel>
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.FrontFreq.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.FrontFreq.Value}"  Foreground="{Binding Metrics.FrontFreq.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.FrontFreq.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.RearFreq.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.RearFreq.Value}"  Foreground="{Binding Metrics.RearFreq.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.RearFreq.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.FreqDiff.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.FreqDiff.Value}"  Foreground="{Binding Metrics.FreqDiff.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.FreqDiff.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.PeakAmpRatio.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.PeakAmpRatio.Value}"  Foreground="{Binding Metrics.PeakAmpRatio.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.PeakAmpRatio.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.LowEnergyRatio.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.LowEnergyRatio.Value}"  Foreground="{Binding Metrics.LowEnergyRatio.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.LowEnergyRatio.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.MidEnergyRatio.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.MidEnergyRatio.Value}"  Foreground="{Binding Metrics.MidEnergyRatio.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.MidEnergyRatio.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.WheelEnergyRatio.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.WheelEnergyRatio.Value}"  Foreground="{Binding Metrics.WheelEnergyRatio.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.WheelEnergyRatio.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.HighEnergyRatio.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.HighEnergyRatio.Value}"  Foreground="{Binding Metrics.HighEnergyRatio.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.HighEnergyRatio.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.LowCoherence.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.LowCoherence.Value}"  Foreground="{Binding Metrics.LowCoherence.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.LowCoherence.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.MidCoherence.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.MidCoherence.Value}"  Foreground="{Binding Metrics.MidCoherence.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.MidCoherence.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.WheelCoherence.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.WheelCoherence.Value}"  Foreground="{Binding Metrics.WheelCoherence.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.WheelCoherence.Target}" />
                    </Grid>
                    <Grid Classes="metricRow" ColumnDefinitions="* Auto Auto">
                        <TextBlock Grid.Column="0" Classes="metricLabel"  Text="{Binding Metrics.HighCoherence.Label}" />
                        <TextBlock Grid.Column="1" Classes="metricValue"  Text="{Binding Metrics.HighCoherence.Value}"  Foreground="{Binding Metrics.HighCoherence.ValueBrush}" />
                        <TextBlock Grid.Column="2" Classes="metricTarget" Text="{Binding Metrics.HighCoherence.Target}" />
                    </Grid>
                </StackPanel>
            </Border>
            <Image IsVisible="{Binding CombinedBalance, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding CombinedBalance}" />
            <Image IsVisible="{Binding ReboundBalance, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding ReboundBalance}" />
            <Image IsVisible="{Binding CompressionBalance, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding CompressionBalance}" />
            <Image IsVisible="{Binding PitchBalance, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding PitchBalance}" />
            <Image IsVisible="{Binding PitchCoherence, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding PitchCoherence}" />
            <Image IsVisible="{Binding GoutScatter, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding GoutScatter}" />
            <Image IsVisible="{Binding CumulativeTravel, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding CumulativeTravel}" />
            <Image IsVisible="{Binding CombinedVelocityFft, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding CombinedVelocityFft}" />
            <Image IsVisible="{Binding CombinedTravelFft, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding CombinedTravelFft}" />
            <Image IsVisible="{Binding CombinedTravelFftHigh, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding CombinedTravelFftHigh}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
