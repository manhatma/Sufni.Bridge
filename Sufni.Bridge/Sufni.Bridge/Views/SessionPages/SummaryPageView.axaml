<UserControl
    x:Class="Sufni.Bridge.Views.SessionPages.SummaryPageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Sufni.Bridge.ViewModels.SessionPages"
    xmlns:items="clr-namespace:Sufni.Bridge.ViewModels.Items"
    d:DesignHeight="600"
    d:DesignWidth="500"
    x:DataType="vm:SummaryPageViewModel"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:SummaryPageViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Border.summary-cell">
            <Setter Property="BorderBrush" Value="{StaticResource SufniBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="{StaticResource SufniBackground}" />
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="TextBlock.summary-title">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Background" Value="#66c2a5" />
            <Setter Property="Foreground" Value="#15191c" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style Selector="Border.summary-header-cell">
            <Setter Property="Background" Value="#66c2a5" />
            <Setter Property="BorderBrush" Value="{StaticResource SufniBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style Selector="Border.summary-header-cell TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#15191c" />
        </Style>
        <Style Selector="ComboBox.summary-setup">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="6,0" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer Width="{Binding $parent[ScrollViewer].Bounds.Width}" Height="{Binding $parent[ScrollViewer].Bounds.Height}" IsScrollChainingEnabled="False">
        <StackPanel Margin="0,0,0,10" Orientation="Vertical" Spacing="12">
            <Grid RowDefinitions="auto auto auto auto" ColumnDefinitions="*">
                <TextBlock Grid.Row="0" Classes="summary-title" Text="RUN DATA" />
                <ItemsControl Grid.Row="1" ItemsSource="{Binding RunDataRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SummaryValueRow">
                            <Grid ColumnDefinitions="110,*">
                                <Border Grid.Column="0" Classes="summary-cell">
                                    <TextBlock Text="{Binding Label}" />
                                </Border>
                                <Border Grid.Column="1" Classes="summary-cell">
                                    <TextBlock HorizontalAlignment="Right" Text="{Binding Value}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Grid Grid.Row="2" ColumnDefinitions="110,*">
                    <Border Grid.Column="0" Classes="summary-cell" Padding="8,2">
                        <TextBlock Text="Setup" VerticalAlignment="Center" />
                    </Border>
                    <Border Grid.Column="1" Classes="summary-cell" Padding="4,2">
                        <Grid ColumnDefinitions="* auto">
                            <!-- View mode: setup name + pencil button -->
                            <TextBlock
                                Grid.Column="0"
                                IsVisible="{Binding !IsEditingSetup}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Text="{Binding SelectedSetup.Name}" />
                            <Button
                                Grid.Column="1"
                                IsVisible="{Binding !IsEditingSetup}"
                                Classes="embedded"
                                Command="{Binding ToggleEditSetupCommand}">
                                <Image Width="14" Source="{SvgImage /Assets/fa-pen-square.svg}" />
                            </Button>
                            <!-- Edit mode: dropdown + refresh button -->
                            <ComboBox
                                Classes="summary-setup"
                                Grid.Column="0"
                                IsVisible="{Binding IsEditingSetup}"
                                HorizontalAlignment="Stretch"
                                ItemsSource="{Binding AvailableSetups}"
                                SelectedItem="{Binding SelectedSetup}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="items:SetupViewModel">
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button
                                Grid.Column="1"
                                IsVisible="{Binding IsEditingSetup}"
                                Classes="embedded"
                                Command="{Binding ChangeSetupCommand}">
                                <Image Width="16" Source="{SvgImage /Assets/fa-rotate-right.svg}" />
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
                <Grid Grid.Row="3" ColumnDefinitions="110,*">
                    <Border Grid.Column="0" Classes="summary-cell">
                        <TextBlock Text="Discipline" />
                    </Border>
                    <Border Grid.Column="1" Classes="summary-cell">
                        <TextBlock HorizontalAlignment="Right" Text="{Binding SelectedSetup.SelectedDiscipline}" />
                    </Border>
                </Grid>
            </Grid>

            <Grid RowDefinitions="auto auto" ColumnDefinitions="*">
                <Grid Grid.Row="0" ColumnDefinitions="110,*,*">
                    <Border Grid.Column="0" Classes="summary-header-cell"><TextBlock Text="" /></Border>
                    <Border Grid.Column="1" Classes="summary-header-cell"><TextBlock Text="FRONT WHEEL" /></Border>
                    <Border Grid.Column="2" Classes="summary-header-cell"><TextBlock Text="REAR WHEEL" /></Border>
                </Grid>
                <ItemsControl Grid.Row="1" ItemsSource="{Binding WheelRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SummaryComparisonRow">
                            <Grid ColumnDefinitions="110,*,*">
                                <Border Grid.Column="0" Classes="summary-cell"><TextBlock Text="{Binding Label}" /></Border>
                                <Border Grid.Column="1" Classes="summary-cell"><TextBlock HorizontalAlignment="Right" Text="{Binding LeftValue}" /></Border>
                                <Border Grid.Column="2" Classes="summary-cell"><TextBlock HorizontalAlignment="Right" Text="{Binding RightValue}" /></Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <Grid RowDefinitions="auto auto" ColumnDefinitions="*">
                <Grid Grid.Row="0" ColumnDefinitions="110,*,*">
                    <Border Grid.Column="0" Classes="summary-header-cell"><TextBlock Text="" /></Border>
                    <Border Grid.Column="1" Classes="summary-header-cell"><TextBlock Text="FORK" /></Border>
                    <Border Grid.Column="2" Classes="summary-header-cell"><TextBlock Text="SHOCK" /></Border>
                </Grid>
                <ItemsControl Grid.Row="1" ItemsSource="{Binding ForkShockRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SummaryComparisonRow">
                            <Grid ColumnDefinitions="110,*,*">
                                <Border Grid.Column="0" Classes="summary-cell"><TextBlock Text="{Binding Label}" /></Border>
                                <Border Grid.Column="1" Classes="summary-cell"><TextBlock HorizontalAlignment="Right" Text="{Binding LeftValue}" /></Border>
                                <Border Grid.Column="2" Classes="summary-cell"><TextBlock HorizontalAlignment="Right" Text="{Binding RightValue}" /></Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
