<UserControl
    x:Class="Sufni.Bridge.Views.SessionPages.DamperPageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:plots="clr-namespace:Sufni.Bridge.Views.Plots"
    xmlns:vm="clr-namespace:Sufni.Bridge.ViewModels.SessionPages"
    d:DesignHeight="600"
    d:DesignWidth="500"
    x:DataType="vm:DamperPageViewModel"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:DamperPageViewModel />
    </Design.DataContext>

    <ScrollViewer Width="{Binding $parent[ScrollViewer].Bounds.Width}" Height="{Binding $parent[ScrollViewer].Bounds.Height}" IsScrollChainingEnabled="False">
        <StackPanel Orientation="Vertical">
            <!--  Velocity distribution comparison  -->
            <Image IsVisible="{Binding VelocityDistributionComparison, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding VelocityDistributionComparison}" />

            <!--  Front velocity histogram  -->
            <StackPanel IsVisible="{Binding FrontVelocityHistogram, Converter={x:Static ObjectConverters.IsNotNull}}">
                <Image Source="{Binding FrontVelocityHistogram}" />
                <Image IsVisible="{Binding FrontLowSpeedVelocityHistogram, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding FrontLowSpeedVelocityHistogram}" />
                <plots:VelocityBandView
                    Margin="50,0,20,0"
                    Title="Front Zone %"
                    HscPercentage="{Binding FrontHscPercentage}"
                    HsrPercentage="{Binding FrontHsrPercentage}"
                    LscPercentage="{Binding FrontLscPercentage}"
                    LsrPercentage="{Binding FrontLsrPercentage}" />
            </StackPanel>

            <!--  Rear velocity histogram  -->
            <StackPanel IsVisible="{Binding RearVelocityHistogram, Converter={x:Static ObjectConverters.IsNotNull}}" Margin="0,24,0,0">
                <Image Source="{Binding RearVelocityHistogram}" />
                <Image IsVisible="{Binding RearLowSpeedVelocityHistogram, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding RearLowSpeedVelocityHistogram}" />
                <plots:VelocityBandView
                    Margin="50,0,20,0"
                    Title="Rear Zone %"
                    HscPercentage="{Binding RearHscPercentage}"
                    HsrPercentage="{Binding RearHsrPercentage}"
                    LscPercentage="{Binding RearLscPercentage}"
                    LsrPercentage="{Binding RearLsrPercentage}" />
            </StackPanel>

            <Image IsVisible="{Binding FrontVelocityTimeCropped, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding FrontVelocityTimeCropped}" />
            <Image IsVisible="{Binding RearVelocityTimeCropped, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding RearVelocityTimeCropped}" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
