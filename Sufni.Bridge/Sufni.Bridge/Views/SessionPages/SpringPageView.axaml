<UserControl
    x:Class="Sufni.Bridge.Views.SessionPages.SpringPageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Sufni.Bridge.ViewModels.SessionPages"
    d:DesignHeight="600"
    d:DesignWidth="500"
    x:DataType="vm:SpringPageViewModel"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:SpringPageViewModel />
    </Design.DataContext>

    <ScrollViewer Width="{Binding $parent[ScrollViewer].Bounds.Width}" Height="{Binding $parent[ScrollViewer].Bounds.Height}" IsScrollChainingEnabled="False">
        <StackPanel Orientation="Vertical">
            <Image IsVisible="{Binding FrontRearTravelScatter, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding FrontRearTravelScatter}" />
            <Image IsVisible="{Binding TravelComparisonHistogram, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding TravelComparisonHistogram}" />
            <Image IsVisible="{Binding FrontTravelHistogram, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding FrontTravelHistogram}" />
            <Image IsVisible="{Binding RearTravelHistogram, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding RearTravelHistogram}" />
            <Image IsVisible="{Binding FrontTravelTimeCropped, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding FrontTravelTimeCropped}" />
            <Image IsVisible="{Binding RearTravelTimeCropped, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding RearTravelTimeCropped}" />
            <Image IsVisible="{Binding FrontTravelFft, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding FrontTravelFft}" />
            <Image IsVisible="{Binding RearTravelFft, Converter={x:Static ObjectConverters.IsNotNull}}" Source="{Binding RearTravelFft}" />
        </StackPanel>
    </ScrollViewer>

</UserControl>
