<UserControl
    x:Class="Sufni.Bridge.Views.SessionPages.NotesPageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Sufni.Bridge.ViewModels.SessionPages"
    d:DesignHeight="600"
    d:DesignWidth="500"
    x:DataType="vm:NotesPageViewModel"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:NotesPageViewModel />
    </Design.DataContext>

    <UserControl.Resources>
        <SolidColorBrush x:Key="PendingAccentBrush" Color="{StaticResource SufniAccentColor}" />
    </UserControl.Resources>

    <Grid
        Width="{Binding $parent[ScrollViewer].Bounds.Width}"
        Margin="0,10,0,0"
        ColumnDefinitions="15 auto 10 * 18 6 * 18 15"
        RowDefinitions="auto auto auto auto auto auto auto auto auto *">

        <Grid.Styles>
            <Style Selector="NumericUpDown">
                <Setter Property="Minimum" Value="0" />
                <Setter Property="Increment" Value="1" />
                <Setter Property="Margin" Value="2" />
                <Setter Property="FontSize" Value="12" />
            </Style>
            <!--  Cap spinner button width so the value stays readable on touch screens.  -->
            <Style Selector="NumericUpDown /template/ ButtonSpinner /template/ RepeatButton">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MaxWidth" Value="28" />
            </Style>
            <!--  Avalonia's default disabled spinner draws a noticeably darker background on
                  iOS dark theme, which reads as "pressed/activated" instead of "disabled at
                  the limit". Strip the background and just fade the chevron.  -->
            <Style Selector="NumericUpDown /template/ ButtonSpinner /template/ RepeatButton:disabled /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
            </Style>
            <Style Selector="NumericUpDown /template/ ButtonSpinner /template/ RepeatButton:disabled">
                <Setter Property="Opacity" Value="0.35" />
            </Style>
            <Style Selector="Label">
                <Setter Property="FontSize" Value="12" />
            </Style>
            <Style Selector="TextBox">
                <Setter Property="FontSize" Value="12" />
            </Style>
            <Style Selector="ToggleButton.pencil">
                <Setter Property="Padding" Value="1" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="ToolTip.Tip" Value="Capture this value as a pending change for the next session" />
            </Style>
            <Style Selector="ToggleButton.pencil /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
            </Style>
            <Style Selector="ToggleButton.pencil:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Opacity" Value="0.8" />
            </Style>
            <Style Selector="ToggleButton.pencil:checked /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{StaticResource PendingAccentBrush}" />
                <Setter Property="BorderBrush" Value="Transparent" />
            </Style>
            <Style Selector="ToggleButton.pencil:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{StaticResource PendingAccentBrush}" />
                <Setter Property="Opacity" Value="0.85" />
            </Style>
        </Grid.Styles>

        <!--  Header row  -->
        <Label
            Grid.Row="0"
            Grid.Column="3"
            HorizontalAlignment="Center"
            Content="Front" />
        <Label
            Grid.Row="0"
            Grid.Column="6"
            HorizontalAlignment="Center"
            Content="Rear" />

        <!--  Spring row  -->
        <Label
            Grid.Row="1"
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Content="Spring:" />
        <TextBox
            Grid.Row="1"
            Grid.Column="3"
            Margin="2"
            VerticalContentAlignment="Center"
            Text="{Binding ForkSettings.SpringRate}" />
        <ToggleButton
            Grid.Row="1"
            Grid.Column="4"
            Classes="pencil"
            IsChecked="{Binding ForkSettings.SpringRateEditing}">
            <Image Width="11" Source="{SvgImage /Assets/fa-pen-square.svg}" />
        </ToggleButton>
        <TextBox
            Grid.Row="1"
            Grid.Column="6"
            Margin="2"
            VerticalContentAlignment="Center"
            Text="{Binding ShockSettings.SpringRate}" />
        <ToggleButton
            Grid.Row="1"
            Grid.Column="7"
            Classes="pencil"
            IsChecked="{Binding ShockSettings.SpringRateEditing}">
            <Image Width="11" Source="{SvgImage /Assets/fa-pen-square.svg}" />
        </ToggleButton>

        <!--  VolSpc row  -->
        <TextBlock
            Grid.Row="2"
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            FontSize="12"
            Foreground="{StaticResource SufniForeground}"
            Text="Volume&#x0A;Spacer:"
            TextAlignment="Right" />
        <NumericUpDown
            Grid.Row="2"
            Grid.Column="3"
            FormatString="F2"
            Increment="0.05"
            Value="{Binding ForkSettings.VolSpc}" />
        <ToggleButton
            Grid.Row="2"
            Grid.Column="4"
            Classes="pencil"
            IsChecked="{Binding ForkSettings.VolSpcEditing}">
            <Image Width="11" Source="{SvgImage /Assets/fa-pen-square.svg}" />
        </ToggleButton>
        <NumericUpDown
            Grid.Row="2"
            Grid.Column="6"
            FormatString="F2"
            Increment="0.05"
            Value="{Binding ShockSettings.VolSpc}" />
        <ToggleButton
            Grid.Row="2"
            Grid.Column="7"
            Classes="pencil"
            IsChecked="{Binding ShockSettings.VolSpcEditing}">
            <Image Width="11" Source="{SvgImage /Assets/fa-pen-square.svg}" />
        </ToggleButton>

        <!--  HSC row  -->
        <Label
            Grid.Row="3"
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Content="HSC:" />
        <NumericUpDown
            Grid.Row="3"
            Grid.Column="3"
            Value="{Binding ForkSettings.HighSpeedCompression}" />
        <ToggleButton
            Grid.Row="3"
            Grid.Column="4"
            Classes="pencil"
            IsChecked="{Binding ForkSettings.HighSpeedCompressionEditing}">
            <Image Width="11" Source="{SvgImage /Assets/fa-pen-square.svg}" />
        </ToggleButton>
        <NumericUpDown
            Grid.Row="3"
            Grid.Column="6"
            Value="{Binding ShockSettings.HighSpeedCompression}" />
        <ToggleButton
            Grid.Row="3"
            Grid.Column="7"
            Classes="pencil"
            IsChecked="{Binding ShockSettings.HighSpeedCompressionEditing}">
            <Image Width="11" Source="{SvgImage /Assets/fa-pen-square.svg}" />
        </ToggleButton>

        <!--  LSC row  -->
        <Label
            Grid.Row="4"
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Content="LSC:" />
        <NumericUpDown
            Grid.Row="4"
            Grid.Column="3"
            Value="{Binding ForkSettings.LowSpeedCompression}" />
        <ToggleButton
            Grid.Row="4"
            Grid.Column="4"
            Classes="pencil"
            IsChecked="{Binding ForkSettings.LowSpeedCompressionEditing}">
            <Image Width="11" Source="{SvgImage /Assets/fa-pen-square.svg}" />
        </ToggleButton>
        <NumericUpDown
            Grid.Row="4"
            Grid.Column="6"
            Value="{Binding ShockSettings.LowSpeedCompression}" />
        <ToggleButton
            Grid.Row="4"
            Grid.Column="7"
            Classes="pencil"
            IsChecked="{Binding ShockSettings.LowSpeedCompressionEditing}">
            <Image Width="11" Source="{SvgImage /Assets/fa-pen-square.svg}" />
        </ToggleButton>

        <!--  LSR row  -->
        <Label
            Grid.Row="5"
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Content="LSR:" />
        <NumericUpDown
            Grid.Row="5"
            Grid.Column="3"
            Value="{Binding ForkSettings.LowSpeedRebound}" />
        <ToggleButton
            Grid.Row="5"
            Grid.Column="4"
            Classes="pencil"
            IsChecked="{Binding ForkSettings.LowSpeedReboundEditing}">
            <Image Width="11" Source="{SvgImage /Assets/fa-pen-square.svg}" />
        </ToggleButton>
        <NumericUpDown
            Grid.Row="5"
            Grid.Column="6"
            Value="{Binding ShockSettings.LowSpeedRebound}" />
        <ToggleButton
            Grid.Row="5"
            Grid.Column="7"
            Classes="pencil"
            IsChecked="{Binding ShockSettings.LowSpeedReboundEditing}">
            <Image Width="11" Source="{SvgImage /Assets/fa-pen-square.svg}" />
        </ToggleButton>

        <!--  HSR row  -->
        <Label
            Grid.Row="6"
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Content="HSR:" />
        <NumericUpDown
            Grid.Row="6"
            Grid.Column="3"
            Value="{Binding ForkSettings.HighSpeedRebound}" />
        <ToggleButton
            Grid.Row="6"
            Grid.Column="4"
            Classes="pencil"
            IsChecked="{Binding ForkSettings.HighSpeedReboundEditing}">
            <Image Width="11" Source="{SvgImage /Assets/fa-pen-square.svg}" />
        </ToggleButton>
        <NumericUpDown
            Grid.Row="6"
            Grid.Column="6"
            Value="{Binding ShockSettings.HighSpeedRebound}" />
        <ToggleButton
            Grid.Row="6"
            Grid.Column="7"
            Classes="pencil"
            IsChecked="{Binding ShockSettings.HighSpeedReboundEditing}">
            <Image Width="11" Source="{SvgImage /Assets/fa-pen-square.svg}" />
        </ToggleButton>

        <!--  Tire pressure row  -->
        <TextBlock
            Grid.Row="7"
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            FontSize="12"
            Foreground="{StaticResource SufniForeground}"
            Text="Tire&#x0A;pressure:"
            TextAlignment="Right" />
        <NumericUpDown
            Grid.Row="7"
            Grid.Column="3"
            FormatString="F2"
            Increment="0.05"
            Value="{Binding ForkSettings.TirePressure}" />
        <ToggleButton
            Grid.Row="7"
            Grid.Column="4"
            Classes="pencil"
            IsChecked="{Binding ForkSettings.TirePressureEditing}">
            <Image Width="11" Source="{SvgImage /Assets/fa-pen-square.svg}" />
        </ToggleButton>
        <NumericUpDown
            Grid.Row="7"
            Grid.Column="6"
            FormatString="F2"
            Increment="0.05"
            Value="{Binding ShockSettings.TirePressure}" />
        <ToggleButton
            Grid.Row="7"
            Grid.Column="7"
            Classes="pencil"
            IsChecked="{Binding ShockSettings.TirePressureEditing}">
            <Image Width="11" Source="{SvgImage /Assets/fa-pen-square.svg}" />
        </ToggleButton>

        <!--  Pending changes for next session  -->
        <Border
            Grid.Row="8"
            Grid.Column="1"
            Grid.ColumnSpan="7"
            Margin="0,8,0,0"
            Padding="6,4"
            BorderBrush="{StaticResource PendingAccentBrush}"
            BorderThickness="1"
            CornerRadius="4"
            IsVisible="{Binding HasPendingChanges}">
            <StackPanel>
                <TextBlock
                    FontSize="10"
                    Opacity="0.65"
                    Text="Pending for next session" />
                <ItemsControl ItemsSource="{Binding PendingChanges}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1" ColumnDefinitions="* auto auto">
                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Text="{Binding Label}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="6,0"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Text="{Binding ValueDisplay}" />
                                <Button
                                    Grid.Column="2"
                                    Classes="embedded"
                                    Command="{Binding RemoveCommand}"
                                    ToolTip.Tip="Remove this pending change">
                                    <Image Width="9" Source="{SvgImage /Assets/fa-xmark.svg}" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!--  Notes box  -->
        <TextBox
            Grid.Row="9"
            Grid.Column="1"
            Grid.ColumnSpan="7"
            Margin="0,10,0,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            VerticalContentAlignment="Top"
            AcceptsReturn="True"
            Text="{Binding Description}"
            TextWrapping="Wrap" />
    </Grid>
</UserControl>
